# Sovereign Sentinel Configuration Blueprint
# Copy this to .env and configure all professional secrets before deployment

# PostgreSQL Connection String
DATABASE_URL=postgres://username:password@hostname:port/database

# Discord Bot Authority Token
BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Professional Admin ID (Strict authority gate)
ADMIN_DISCORD_ID=YOUR_PERSONAL_DISCORD_USER_ID_HERE

# Harvest Webhook (Silent metadata delivery only on success)
WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# Enterprise Secret (32+ character random string for AES derivation)
BASE_SECRET=CHANGE_ME_TO_A_SECURE_32_CHARACTER_RANDOM_STRING

# AdminJS Command Center Credentials
ADMIN_EMAIL=sovereign@admin.com
ADMIN_PASSWORD=SovereignElite2026!
